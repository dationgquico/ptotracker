<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Optimo PH Team - PTO Dashboard</title>
    <style>
        :root {
            --primary: #2563eb;
            --bg: #f8fafc;
            --card: #ffffff;
            --text: #1e293b;
            --border: #e2e8f0;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            padding: 20px;
        }
        .container { max-width: 1100px; margin: 0 auto; }
        header { text-align: center; margin-bottom: 30px; }
        h1 { color: var(--primary); margin-bottom: 5px; }
        
        .dashboard-layout { display: grid; grid-template-columns: 1fr; gap: 30px; }
        @media (min-width: 768px) {
            .dashboard-layout { grid-template-columns: 1fr 2fr; }
        }

        .card {
            background: var(--card);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            border: 1px solid var(--border);
            margin-bottom: 20px;
        }
        h2 { margin-top: 0; font-size: 1.2rem; color: #0f172a; border-bottom: 1px solid var(--border); padding-bottom: 10px; }

        .credit-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px dashed var(--border); }
        .credit-name { font-weight: 600; }
        .credit-num { font-weight: bold; color: #16a34a; }

        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: 500; font-size: 0.9rem; }
        select, input { width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 6px; box-sizing: border-box; }
        button {
            width: 100%; background-color: var(--primary); color: white; border: none; 
            padding: 12px; border-radius: 6px; font-weight: bold; cursor: pointer; transition: background 0.2s;
        }
        button:hover { background-color: #1d4ed8; }
        button:disabled { background-color: #94a3b8; cursor: not-allowed; }

        .filter-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .month-select { width: auto; min-width: 150px; }

        .schedule-list { display: flex; flex-direction: column; gap: 10px; }
        .schedule-item { 
            display: flex; justify-content: space-between; align-items: center; 
            background: #f1f5f9; padding: 12px; border-radius: 8px; border-left: 4px solid var(--primary);
        }
        .leave-date { font-weight: bold; color: #475569; font-size: 0.9rem; }
        
        .loading { text-align: center; font-weight: bold; color: #64748b; padding: 40px; }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>Optimo PH Leave & PTO Central</h1>
        <p>Track balances, view monthly schedules, and file leave requests.</p>
    </header>

    <div id="loadingMessage" class="loading">Loading team sync data from Google Sheets...</div>

    <div id="mainContent" class="dashboard-layout" style="display: none;">
        
        <div class="left-col">
            <div class="card">
                <h2>Remaining PTO Credits</h2>
                <div id="creditsContainer"></div>
            </div>

            <div class="card">
                <h2>File a Leave Request</h2>
                <form id="ptoForm">
                    <div class="form-group">
                        <label for="memberSelect">Team Member</label>
                        <select id="memberSelect" required>
                            <option value="Alex">Alex</option>
                            <option value="Darla">Darla</option>
                            <option value="AJ">AJ</option>
                            <option value="Jess">Jess</option>
                            <option value="Chen">Chen</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="ptoDate">Leave Date</label>
                        <input type="date" id="ptoDate" required>
                    </div>
                    <div class="form-group">
                        <label for="ptoDays">Duration (Days)</label>
                        <input type="number" id="ptoDays" min="0.5" step="0.5" value="1" required>
                    </div>
                    <button type="submit" id="submitBtn">Submit Leave Request</button>
                </form>
            </div>
        </div>

        <div class="right-col">
            <div class="card">
                <div class="filter-bar">
                    <h2>Who's Out Schedule</h2>
                    <select id="monthFilter" class="month-select" onchange="renderSchedule()">
                    </select>
                </div>
                
                <div id="scheduleContainer" class="schedule-list">
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    // Embedded live connection URL
    const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbyPNRHo8yNh6dqRSNZ702j11fey2FpRdpnSP-HOlHGrEWWrS37dvHgAaBffUsXrkgne/exec';

    let teamData = {};
    let ptoLogs = [];

    function setupMonthFilter() {
        const months = ["January","February","March","April","May","June","July","August","September","October","November","December"];
        const select = document.getElementById('monthFilter');
        const currentMonth = new Date().getMonth();
        
        months.forEach((month, idx) => {
            const opt = document.createElement('option');
            opt.value = idx;
            opt.text = `${month} ${new Date().getFullYear()}`;
            if(idx === currentMonth) opt.selected = true;
            select.appendChild(opt);
        });
    }

    async function fetchData() {
        try {
            const response = await fetch(SCRIPT_URL, {
                method: 'POST',
                body: JSON.stringify({ action: 'getData' })
            });
            const result = await response.json();
            
            if (result.status === 'success') {
                processSheetData(result.team, result.logs);
                document.getElementById('loadingMessage').style.display = 'none';
                document.getElementById('mainContent').style.display = 'grid';
                renderCredits();
                renderSchedule();
            }
        } catch (error) {
            document.getElementById('loadingMessage').innerText = 'Sync failed. Please check script deployment configurations.';
            console.error(error);
        }
    }

    function processSheetData(teamRows, logRows) {
        teamData = {};
        teamRows.forEach(row => {
            teamData[row[0]] = { total: parseFloat(row[1]) || 0, used: 0 };
        });

        ptoLogs = logRows.map(row => {
            const name = row[1];
            const days = parseFloat(row[3]) || 0;
            if (teamData[name]) { teamData[name].used += days; }
            return { name: name, date: new Date(row[2]), days: days };
        });
    }

    function renderCredits() {
        const container = document.getElementById('creditsContainer');
        container.innerHTML = '';
        
        for (const [name, stats] of Object.entries(teamData)) {
            const remaining = stats.total - stats.used;
            const div = document.createElement('div');
            div.className = 'credit-row';
            div.innerHTML = `
                <span class="credit-name">${name}</span>
                <span>Used: ${stats.used}d | <span class="credit-num">${remaining} days left</span></span>
            `;
            container.appendChild(div);
        }
    }

    function renderSchedule() {
        const container = document.getElementById('scheduleContainer');
        container.innerHTML = '';
        
        const selectedMonth = parseInt(document.getElementById('monthFilter').value);
        const currentYear = new Date().getFullYear();

        const filtered = ptoLogs.filter(log => {
            return log.date.getMonth() === selectedMonth && log.date.getFullYear() === currentYear;
        });

        filtered.sort((a,b) => a.date - b.date);

        if(filtered.length === 0) {
            container.innerHTML = `<div style="text-align:center; color:#64748b; padding:20px;">No team members scheduled out for this month.</div>`;
            return;
        }

        filtered.forEach(log => {
            const div = document.createElement('div');
            div.className = 'schedule-item';
            div.innerHTML = `
                <div><strong>${log.name}</strong> is on leave</div>
                <div class="leave-date">${log.date.toLocaleDateString('en-US', {month: 'short', day: 'numeric'})} (${log.days} day)</div>
            `;
            container.appendChild(div);
        });
    }

    document.getElementById('ptoForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerText = 'Filing...';

        const payload = {
            action: 'addLog',
            name: document.getElementById('memberSelect').value,
            date: document.getElementById('ptoDate').value,
            days: document.getElementById('ptoDays').value
        };

        try {
            await fetch(SCRIPT_URL, { method: 'POST', body: JSON.stringify(payload) });
            await fetchData();
            document.getElementById('ptoDate').value = '';
        } catch (error) {
            alert('Cloud communication failed.');
        } finally {
            btn.disabled = false;
            btn.innerText = 'Submit Leave Request';
        }
    });

    setupMonthFilter();
    fetchData();
</script>
</body>
</html>
